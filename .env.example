# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# INSAT Cloud Forecasting - Environment Configuration Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# INSTRUCTIONS FOR TEAM DEPLOYMENT:
# 1. Copy this file to .env (will be auto-ignored by .gitignore)
# 2. Fill in your values below based on your setup
# 3. IMPORTANT: Never commit .env to GitHub - it contains credentials!
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── MOSDAC DOWNLOAD CREDENTIALS ────────────────────────────────────────
# Register at: https://www.mosdac.gov.in to obtain these
# SECURITY: This file (.env) is in .gitignore - never commit it!

MOSDAC_USERNAME=your_email@example.com
MOSDAC_PASSWORD=your_password_here
MOSDAC_FOLDER_PATH=/Order/Apr26_178218

# ── DATA DIRECTORIES ───────────────────────────────────────────────────
# Set these paths based on your system. Use relative or absolute paths.
# Defaults to project root subdirectories if not set.

INSAT_RAW_DIR=./raw
INSAT_PROCESSED_DIR=./processed
INSAT_SEQUENCES_DIR=./sequences
INSAT_RESULTS_DIR=./results
INSAT_EVALUATION_DIR=./evaluation
INSAT_GEOTIFFS_DIR=./geotiffs
INSAT_CHECKPOINTS_DIR=./checkpoints

# ── FLEXIBLE DATA SUBSET CONFIGURATION ────────────────────────────────
# Critical for team collaboration:
# - Set to 50 if your team is working on initial 50 files
# - Set to 163 for full dataset processing
# This allows different team members to work with different data subsets

NUM_FILES_TO_PROCESS=50

# ── MODEL & TRAINING CONFIGURATION ────────────────────────────────────
# Adjust BATCH_SIZE based on available GPU memory:
#   - 4GB GPU  : BATCH_SIZE=2
#   - 8GB GPU  : BATCH_SIZE=4
#   - 16GB GPU : BATCH_SIZE=8
#   - 24GB+ GPU: BATCH_SIZE=16

BATCH_SIZE=4
LEARNING_RATE=1e-4
MAX_EPOCHS=50
TRAIN_TEST_SPLIT=0.8
RANDOM_SEED=42

# ==================== Streamlit Configuration ====================
# Dashboard settings
STREAMLIT_PORT=8501
STREAMLIT_HOST="localhost"
STREAMLIT_THEME="dark"

# ==================== Logging & Debugging ====================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Enable debug mode for detailed logging
DEBUG_MODE=False

# Save intermediate visualizations
SAVE_VISUALIZATIONS=True

# ==================== Optional: Cloud Storage ====================
# For backups or distributed training (optional)
# AWS_BUCKET_NAME="your-bucket-name"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ==================== Optional: Weights & Biases (W&B) ====================
# For experiment tracking (uncomment to enable)
# WANDB_API_KEY="your-wandb-api-key"
# WANDB_PROJECT="cloud-forecasting"
# WANDB_ENTITY="your-username"

# ==================== Optional: Email Notifications ====================
# For training completion alerts (uncomment to enable)
# SMTP_SERVER="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USERNAME="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# NOTIFY_EMAIL="recipient@example.com"

# ==================== Application Settings ====================
# Timezone for timestamps
TIMEZONE="UTC"

# Output image format
IMAGE_FORMAT="png"

# Model checkpoint naming
CHECKPOINT_PREFIX="model"

# ==================== Development ====================
# Set to True to use dummy data for testing
USE_DUMMY_DATA=False

# Number of dummy sequences for testing
DUMMY_SEQUENCES=10

# Profiling (PyTorch profiler)
ENABLE_PROFILER=False

# ==================== Feature Flags ====================
# Enable experimental features
ENABLE_ATTENTION=True
ENABLE_CONDITIONING=False
ENABLE_EMA=True  # Exponential Moving Average for model

# ==================== Validation ====================
# Validation frequency (every N epochs)
VAL_CHECK_INTERVAL=5

# Early stopping patience (epochs without improvement)
EARLY_STOPPING_PATIENCE=10
