# Environment Variables Template
# Copy this file to .env and fill in with your actual values
# IMPORTANT: .env should NOT be committed to git (included in .gitignore)

# ==================== MOSDAC Credentials ====================
# Register at: https://www.mosdac.gov.in
MOSDAC_USERNAME="your_email@example.com"
MOSDAC_PASSWORD="your_password"
MOSDAC_FOLDER_PATH="/Order/Apr26_178218"
MOSDAC_BASE_URL="https://www.mosdac.gov.in"

# ==================== Data Paths ====================
# Base directory for all data
DATA_DIR="D:/Insat_data"

# Subdirectories (created automatically)
RAW_DIR="${DATA_DIR}/raw"
PROCESSED_DIR="${DATA_DIR}/processed"
SEQUENCE_DIR="${DATA_DIR}/sequences"
RESULTS_DIR="${DATA_DIR}/results"
CKPT_DIR="${DATA_DIR}/checkpoints"
EVAL_DIR="${DATA_DIR}/evaluation"

# ==================== Model Configuration ====================
# Image and data parameters
IMG_SIZE=64
CHANNELS=3
INPUT_FRAMES=4
TARGET_FRAMES=1
TOTAL_WINDOW=5  # INPUT_FRAMES + TARGET_FRAMES

# Training parameters
BATCH_SIZE=4
LEARNING_RATE=1e-4
MAX_EPOCHS=50
NUM_WORKERS=4  # Parallel data loading workers

# Diffusion parameters
TIMESTEPS=1000
BETA_START=1e-4
BETA_END=0.02

# ==================== Hardware Configuration ====================
# GPU settings
USE_GPU=True
CUDA_VISIBLE_DEVICES="0"  # GPU device IDs (comma-separated for multiple)
NUM_GPUS=1

# CPU settings (fallback if GPU unavailable)
NUM_CPU_WORKERS=4

# ==================== Streamlit Configuration ====================
# Dashboard settings
STREAMLIT_PORT=8501
STREAMLIT_HOST="localhost"
STREAMLIT_THEME="dark"

# ==================== Logging & Debugging ====================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Enable debug mode for detailed logging
DEBUG_MODE=False

# Save intermediate visualizations
SAVE_VISUALIZATIONS=True

# ==================== Optional: Cloud Storage ====================
# For backups or distributed training (optional)
# AWS_BUCKET_NAME="your-bucket-name"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ==================== Optional: Weights & Biases (W&B) ====================
# For experiment tracking (uncomment to enable)
# WANDB_API_KEY="your-wandb-api-key"
# WANDB_PROJECT="cloud-forecasting"
# WANDB_ENTITY="your-username"

# ==================== Optional: Email Notifications ====================
# For training completion alerts (uncomment to enable)
# SMTP_SERVER="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USERNAME="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# NOTIFY_EMAIL="recipient@example.com"

# ==================== Application Settings ====================
# Timezone for timestamps
TIMEZONE="UTC"

# Output image format
IMAGE_FORMAT="png"

# Model checkpoint naming
CHECKPOINT_PREFIX="model"

# ==================== Development ====================
# Set to True to use dummy data for testing
USE_DUMMY_DATA=False

# Number of dummy sequences for testing
DUMMY_SEQUENCES=10

# Profiling (PyTorch profiler)
ENABLE_PROFILER=False

# ==================== Feature Flags ====================
# Enable experimental features
ENABLE_ATTENTION=True
ENABLE_CONDITIONING=False
ENABLE_EMA=True  # Exponential Moving Average for model

# ==================== Validation ====================
# Validation frequency (every N epochs)
VAL_CHECK_INTERVAL=5

# Early stopping patience (epochs without improvement)
EARLY_STOPPING_PATIENCE=10
